meta {
  name: Creer une commande
  type: http
  seq: 2
}

post {
  url: {{api_url}}/commandes
  body: json
  auth: basic
}

headers {
  Content-Type: application/json
  Accept: application/json
}

auth:basic {
  username: {{dervenn_basic_auth_username}}
  password: {{food_basic_auth_password}}
}

body:json {
  {
    "action": "create",
    "commandeNumber": {{commande_number}},
    "baseType": "{{base_type}}",
    "comment": "{{comment}}"
  }
}
