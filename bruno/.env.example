# API Gateway URL, without trailing slash
DERVENN_API_URL=https://example.execute-api.eu-west-3.amazonaws.com/prod

# Shared username plus service-specific passwords
DERVENN_BASIC_AUTH_USERNAME=food
DERVENN_FOOD_BASIC_AUTH_PASSWORD=change-me
DERVENN_BIKE_BASIC_AUTH_PASSWORD=change-me

# Default request values
DERVENN_COMMANDE_NUMBER=1
DERVENN_BASE_TYPE=TOMATE
DERVENN_COMMENT=Sans oignons
DERVENN_STATUS=EN_COURS
