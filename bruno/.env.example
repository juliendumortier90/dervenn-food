# API Gateway URL, without trailing slash
FESTIVAL_API_URL=https://example.execute-api.eu-west-3.amazonaws.com/prod

# Same credentials as FESTIVAL_BASIC_AUTH_USERNAME / FESTIVAL_BASIC_AUTH_PASSWORD
FESTIVAL_BASIC_AUTH_USERNAME=food
FESTIVAL_BASIC_AUTH_PASSWORD=change-me

# Default request values
FESTIVAL_COMMANDE_NUMBER=1
FESTIVAL_BASE_TYPE=TOMATE
FESTIVAL_COMMENT=Sans oignons
FESTIVAL_STATUS=EN_COURS
