meta {
  name: Supprimer une commande
  type: http
  seq: 4
}

post {
  url: {{api_url}}/commandes?action=delete
  body: json
  auth: basic
}

headers {
  Content-Type: application/json
  Accept: application/json
}

auth:basic {
  username: {{dervenn_basic_auth_username}}
  password: {{food_basic_auth_password}}
}

body:json {
  {
    "action": "delete",
    "commandeNumber": {{commande_number}}
  }
}
